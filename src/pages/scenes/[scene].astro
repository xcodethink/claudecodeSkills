---
import Base from '../../layouts/Base.astro';
import SkillCard from '../../components/SkillCard.astro';
import Icon from '../../components/Icon.astro';
import { loadCategories, getSkillsByCategory } from '../../lib/skills';

export function getStaticPaths() {
  const categories = loadCategories();
  return categories.map(cat => ({
    params: { scene: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const lang = 'cn';
const skills = getSkillsByCategory(category.id, lang);

const modeLabel: Record<string, string> = {
  solo: 'Solo',
  multi: '多人协作',
  'solo-or-multi': '可多人',
};
---

<Base title={category.name_cn} description={category.description_cn} lang={lang}>
  <div class="max-w-6xl mx-auto px-8 py-16">
    <a href="/scenes" class="text-sm text-text-tertiary hover:text-accent transition-colors duration-200">
      <Icon name="arrow-left" size={14} class="inline mr-1" />
      返回场景列表
    </a>

    <div class="mt-8 flex items-start gap-4">
      {category.phase === 'pipeline' ? (
        <span class="shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-accent/10 to-accent/5 text-accent text-lg font-semibold flex items-center justify-center">
          {category.order}
        </span>
      ) : (
        <div class="w-12 h-12 rounded-xl bg-surface-alt flex items-center justify-center text-text-secondary">
          <Icon name={category.icon} size={22} />
        </div>
      )}
      <div>
        <div class="flex items-center gap-2">
          <h1 class="text-3xl font-extrabold tracking-tight text-text-primary">{category.name_cn}</h1>
          <span class={`text-xs px-2 py-0.5 rounded-full ${
            category.mode === 'multi' || category.mode === 'solo-or-multi'
              ? 'bg-accent-muted text-accent'
              : 'bg-surface-alt text-text-tertiary'
          }`}>
            {modeLabel[category.mode]}
          </span>
        </div>
        <p class="text-sm text-text-secondary mt-1">{category.description_cn}</p>
      </div>
    </div>

    <p class="text-sm text-text-tertiary mt-6">{skills.length} 个技能</p>

    {skills.length > 0 ? (
      <div class="grid sm:grid-cols-2 gap-6 mt-8">
        {skills.map(skill => (
          <SkillCard
            title={skill.title}
            source={skill.source}
            highlight={skill.highlight}
            verified={skill.verified}
            type={skill.type}
            difficulty={skill.difficulty}
            tags={skill.tags}
            compatibleWith={skill.compatibleWith}
            href={`/skills/${skill.source}/${skill.slug}`}
          />
        ))}
      </div>
    ) : (
      <div class="mt-16 text-center text-text-tertiary py-20">
        <Icon name="info" size={32} class="mx-auto mb-3 text-text-tertiary" />
        <p class="text-sm">暂无此场景的技能</p>
      </div>
    )}
  </div>
</Base>
