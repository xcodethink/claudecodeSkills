---
/**
 * Dynamic catch-all page for the admin console.
 * The path is determined by the CONSOLE_PATH env var at build time.
 * This page is NOT included in the sitemap and has no external links to it.
 */
import ConsoleApp from '../components/admin/ConsoleApp.tsx';

// Read console path from env (build-time)
const consolePath = import.meta.env.CONSOLE_PATH || 'console';

export function getStaticPaths() {
  const consolePath = import.meta.env.CONSOLE_PATH || 'console';
  return [{ params: { console: consolePath } }];
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    @import "tailwindcss";

    :root {
      --color-accent: #8B5CF6;
      --color-accent-hover: #7C3AED;
      --color-surface: #0f0f10;
      --color-surface-alt: #18181b;
      --color-text-primary: #fafafa;
      --color-text-secondary: #a1a1aa;
      --color-text-tertiary: #52525b;
      --color-border: #27272a;
      --color-success: #10B981;
      --color-warning: #F59E0B;
      --color-error: #EF4444;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--color-surface);
      color: var(--color-text-primary);
      min-height: 100vh;
    }
  </style>
</head>
<body>
  <ConsoleApp client:load apiBase="/api/pipeline" />
</body>
</html>
