---
import Base from '../../layouts/Base.astro';
import WorkflowCard from '../../components/WorkflowCard.astro';
import { getWorkflowsWithSkills } from '../../lib/skills';

const lang = 'cn';
const workflows = getWorkflowsWithSkills(lang);
---

<Base title="工作流" description="目标驱动的完整工作流 — 每一步都有技能、标准和验证" keywords="claude code workflows, ai workflow, development pipeline" lang={lang}>
  <div class="max-w-6xl mx-auto px-8 py-16">
    <h1 class="text-3xl font-extrabold tracking-tight text-text-primary">工作流</h1>
    <p class="text-base text-text-secondary mt-3">
      围绕具体目标的完整执行流程，每一步都有技能支撑、质量标准和验证门
    </p>

    <div class="grid gap-6 mt-10">
      {workflows.map(wf => (
        <WorkflowCard
          id={wf.id}
          name={wf.name_cn}
          icon={wf.icon}
          description={wf.description_cn}
          coverage={wf.coverage}
          stepCount={wf.steps.length}
          lang={lang}
        />
      ))}
    </div>
  </div>
</Base>
