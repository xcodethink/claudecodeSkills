---
import Base from '../layouts/Base.astro';
import CopyButton from '../components/CopyButton.tsx';
import Icon from '../components/Icon.astro';
import { getStats } from '../lib/skills';

const stats = getStats();

const mcpConfig = JSON.stringify({
  "claude-code-skills": {
    "type": "url",
    "url": "https://claudecodeskills.wayjet.io/mcp"
  }
}, null, 2);
---

<Base title="Quick Setup | 快速接入" description="Set up Claude Code Skills in 30 seconds">
  <div class="max-w-4xl mx-auto px-4 sm:px-8 py-16">
    <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-text-primary">
      <span data-lang-cn>快速接入</span>
      <span data-lang-en>Quick Setup</span>
    </h1>
    <p class="text-base text-text-secondary mt-3">
      <span data-lang-cn>MCP 全量接入，{stats.totalCn} 个技能全部激活</span>
      <span data-lang-en>Full MCP access, {stats.totalCn} skills activated</span>
    </p>

    <section class="mt-10 p-6 rounded-2xl border border-border/60 hover:border-accent/20 transition-colors duration-300">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-accent/10 to-accent/5 flex items-center justify-center">
          <Icon name="code" size={20} class="text-accent" />
        </div>
        <div>
          <h2 class="text-lg font-semibold text-text-primary">Claude Code</h2>
          <p class="text-sm text-text-secondary">
            <span data-lang-cn>在 settings.json 中添加一行配置即可</span>
            <span data-lang-en>Just add one line to settings.json</span>
          </p>
        </div>
      </div>

      <div class="mt-5">
        <p class="text-sm text-text-secondary mb-3">
          <span data-lang-cn>在 <code class="text-xs bg-surface-alt px-1.5 py-0.5 rounded-lg font-mono">~/.claude/settings.json</code> 的 mcpServers 中添加：</span>
          <span data-lang-en>Add to mcpServers in <code class="text-xs bg-surface-alt px-1.5 py-0.5 rounded-lg font-mono">~/.claude/settings.json</code>:</span>
        </p>
        <div class="relative bg-gray-900 text-gray-100 rounded-xl p-5 font-mono text-sm">
          <pre>{mcpConfig}</pre>
          <div class="absolute top-3 right-3">
            <CopyButton client:idle text={mcpConfig} label="Copy" />
          </div>
        </div>
        <p class="text-xs text-text-tertiary mt-4">
          <span data-lang-cn>保存后重启 Claude Code，所有技能自动可用。</span>
          <span data-lang-en>Save and restart Claude Code. All skills are ready to use.</span>
        </p>
      </div>
    </section>
  </div>
</Base>
