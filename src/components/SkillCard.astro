---
interface Props {
  title: string;
  source: string;
  highlight?: string;
  verified?: boolean;
  type?: string;
  difficulty?: string;
  href: string;
  tags?: string[];
}

const { title, source, highlight, verified, type, difficulty, href, tags = [] } = Astro.props;

const typeLabels_cn: Record<string, string> = {
  discipline: '纪律型',
  tool: '工具型',
  process: '流程型',
  reference: '参考型',
};
const typeLabels_en: Record<string, string> = {
  discipline: 'Discipline',
  tool: 'Tool',
  process: 'Process',
  reference: 'Reference',
};

const diffLabels_cn: Record<string, string> = {
  starter: '入门',
  intermediate: '中级',
  advanced: '高级',
};
const diffLabels_en: Record<string, string> = {
  starter: 'Starter',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

const difficultyStyles: Record<string, string> = {
  starter: 'text-green-700 bg-green-50 dark:text-green-400 dark:bg-green-900/20',
  intermediate: 'text-yellow-700 bg-yellow-50 dark:text-yellow-400 dark:bg-yellow-900/20',
  advanced: 'text-red-700 bg-red-50 dark:text-red-400 dark:bg-red-900/20',
};
---

<a href={href} class="block p-5 rounded-2xl border border-border/60 bg-surface hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300 group">
  <div class="flex items-start justify-between gap-2">
    <h3 class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors duration-200 line-clamp-1">{title}</h3>
    {verified && (
      <span class="shrink-0 text-xs px-2 py-0.5 rounded-full bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-400 font-medium">
        Verified
      </span>
    )}
  </div>

  {highlight && (
    <p class="text-sm text-text-secondary mt-2 line-clamp-2 leading-relaxed">{highlight}</p>
  )}

  <div class="flex items-center gap-2 mt-3">
    {type && (
      <span class="text-xs px-2 py-0.5 rounded-full bg-surface-alt text-text-secondary">
        <span data-lang-cn>{typeLabels_cn[type] || type}</span>
        <span data-lang-en>{typeLabels_en[type] || type}</span>
      </span>
    )}
    {difficulty && (
      <span class={`text-xs px-2 py-0.5 rounded-full ${difficultyStyles[difficulty] || 'bg-surface-alt text-text-secondary'}`}>
        <span data-lang-cn>{diffLabels_cn[difficulty] || difficulty}</span>
        <span data-lang-en>{diffLabels_en[difficulty] || difficulty}</span>
      </span>
    )}
  </div>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-2.5">
      {tags.slice(0, 3).map(tag => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-accent-muted text-accent">{tag}</span>
      ))}
    </div>
  )}
</a>
