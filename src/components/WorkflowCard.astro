---
import Icon from './Icon.astro';

interface Props {
  id: string;
  name: string;
  icon: string;
  description: string;
  coverage: 'full' | 'partial';
  stepCount: number;
  lang?: string;
}

const { id, name, icon, description, coverage, stepCount, lang = 'cn' } = Astro.props;

const coverageLabel = coverage === 'full'
  ? (lang === 'cn' ? '完整覆盖' : 'Full Coverage')
  : (lang === 'cn' ? '部分覆盖' : 'Partial');
---

<a href={`/workflows/${id}`} class="block p-6 rounded-2xl border border-border/60 bg-surface hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300 group">
  <div class="flex items-start gap-3">
    <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-accent/10 to-accent/5 flex items-center justify-center text-text-secondary group-hover:text-accent transition-colors duration-200">
      <Icon name={icon} size={18} />
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent transition-colors duration-200">{name}</h3>
        <span class={`text-xs px-2 py-0.5 rounded-full shrink-0 ${
          coverage === 'full'
            ? 'bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-400'
            : 'bg-amber-50 text-amber-700 dark:bg-amber-900/20 dark:text-amber-400'
        }`}>
          {coverageLabel}
        </span>
      </div>
      <p class="text-sm text-text-secondary mt-1.5 leading-relaxed">{description}</p>
      <p class="text-xs text-text-tertiary mt-2.5 font-mono">{stepCount} {lang === 'cn' ? '个步骤' : 'steps'}</p>
    </div>
  </div>
</a>
