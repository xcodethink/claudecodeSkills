---
import CopyButton from './CopyButton.tsx';

interface Props {
  id: string;
  name: string;
  icon: string;
  description: string;
  skillCount: number;
  why: string;
  copyText?: string;
  lang?: 'cn' | 'en';
}

const { id, name, icon, description, skillCount, why, copyText = '', lang = 'cn' } = Astro.props;

const iconMap: Record<string, string> = {
  rocket: '🚀',
  mag: '🔍',
  clipboard: '📋',
  robot: '🤖',
  art: '🎨',
  memo: '📝',
};
---

<div class="p-5 rounded-xl border border-border hover:border-brand/30 transition-all">
  <div class="flex items-start justify-between">
    <div class="flex items-center gap-2">
      <span class="text-xl">{iconMap[icon] || '📦'}</span>
      <h3 class="font-semibold">{name}</h3>
    </div>
    <span class="text-xs text-text-secondary">{skillCount} {lang === 'cn' ? '个技能' : 'skills'}</span>
  </div>

  <p class="text-sm text-text-secondary mt-2">{description}</p>

  <p class="text-xs text-text-secondary mt-2 italic">
    {lang === 'cn' ? '为什么选这几个：' : 'Why these: '}{why}
  </p>

  <div class="flex items-center gap-2 mt-3">
    <a href={`/bundles/${id}`} class="text-sm text-brand hover:text-brand-dark">
      {lang === 'cn' ? '查看详情 →' : 'View details →'}
    </a>
    {copyText && (
      <CopyButton
        client:idle
        text={copyText}
        label={lang === 'cn' ? '复制全部' : 'Copy All'}
        variant="secondary"
      />
    )}
  </div>
</div>
